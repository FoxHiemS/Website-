        <div class="timeline__section">
        <div class="timeline__section__bead"></div>
        <div class="timeline__section__content">
            <h2>Müşteri Odaklılık</h2>
            <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Aut enim sunt modi qui cum eveniet magni iure laudantium vitae. At corporis sequi porro doloremque obcaecati repudiandae nemo? Delectus, praesentium fuga?</p>
        </div>
        </div>

        <div class="timeline__section">
        <div class="timeline__section__bead"></div>
        <div class="timeline__section__content">
            <h2>Sürdürülebilirlik</h2>
            <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Aut enim sunt modi qui cum eveniet magni iure laudantium vitae. At corporis sequi porro doloremque obcaecati repudiandae nemo? Delectus, praesentium fuga?</p>
        </div>
        </div>

    </div>
    </div>

    <script>
        function qs(selector, all) {
        if (all === void 0) {
            all = false;
        }
        
        if (all) {
            return document.querySelectorAll(selector);
        } else {
            return document.querySelector(selector);
        }
        }

        var sections = qs(".timeline__section", true);
        var timeline = qs(".timeline");
        var line = qs(".timeline__line");

        line.style.bottom = "calc(100% - 20px)";
        var prevScrollY = window.scrollY;
        var up, down;
        var full = false;
        var set = 0;
        var targetY = window.innerHeight * 0.8;

        function scrollHandler(e) {
        var scrollY = window.scrollY;

        up = scrollY < prevScrollY;
        down = !up;

        var timelineRect = timeline.getBoundingClientRect();
        var lineRect = line.getBoundingClientRect();
        // const lineHeight = lineRect.bottom - lineRect.top;
        var dist = targetY - timelineRect.top;

        console.log(dist);

        if (down && !full) {
            set = Math.max(set, dist);
            line.style.bottom = "calc(100% - " + set + "px)";
        }

        if (dist > timeline.offsetHeight + 50 && !full) {
            full = true;
            line.style.bottom = "-50px";
        }

        sections.forEach(function(item) {
            // console.log(item);
            var rect = item.getBoundingClientRect();
            //     console.log(rect);

            if (rect.top + item.offsetHeight / 5 < targetY) {
            item.classList.add("show-me");
            }
        });

        // console.log(up, down);
        prevScrollY = window.scrollY;
        }

        scrollHandler();
        line.style.display = "block";
        window.addEventListener("scroll", scrollHandler);

    </script>

</body>
</html>
